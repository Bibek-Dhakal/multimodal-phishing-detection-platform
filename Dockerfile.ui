FROM python:3.12-slim

WORKDIR /app

ENV PIP_DEFAULT_TIMEOUT=1000
ENV PYTHONUNBUFFERED=1

# Copy and install UI-specific requirements
COPY requirements.docker.ui.txt .
RUN pip install --no-cache-dir -r requirements.docker.ui.txt

COPY . .

CMD ["streamlit", "run", "app/ui.py", "--server.port", "8501", "--server.address", "0.0.0.0"]
